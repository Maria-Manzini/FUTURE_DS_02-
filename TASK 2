        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.ticker as mtick\n",
        "import numpy as np\n",
        "\n",
        "print(\"Libraries ready \")\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "np.random.seed(42)\n",
        "n = 200\n",
        "\n",
        "data = {\n",
        "    'CustomerID': [f'C{str(i).zfill(4)}' for i in range(1, n+1)],\n",
        "    'Tenure_Months': np.random.randint(1, 36, n),\n",
        "    'Monthly_Charge': np.random.choice([9.99, 19.99, 29.99, 49.99], n),\n",
        "    'Contract_Type': np.random.choice(\n",
        "        ['Month-to-Month', 'One Year', 'Two Year'], n,\n",
        "        p=[0.5, 0.3, 0.2]),\n",
        "    'Support_Tickets': np.random.randint(0, 10, n),\n",
        "    'Churned': np.random.choice([0, 1], n, p=[0.65, 0.35])\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "churned = df[df['Churned'] == 1]\n",
        "retained = df[df['Churned'] == 0]\n",
        "\n",
        "print(f\"Total Customers: {len(df)}\")\n",
        "print(f\"Churned: {len(churned)} ({len(churned)/len(df)*100:.1f}%)\")\n",
        "print(f\"Retained: {len(retained)} ({len(retained)/len(df)*100:.1f}%)\")\n",
        "print(df.head())"
      ],
      "metadata": {
